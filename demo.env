# Django Settings
DJANGO_SECRET_KEY = "your-django-secret-key"
DEBUG = True  # Set to False in Production

# Database configuration
DB_NAME = 'aps_db'
DB_USER = 'aps_db_user'
DB_PASSWORD = ''
DB_HOST = 'localhost'
DB_PORT = '5432'

# Email Configuration
EMAIL_HOST_USER = "your-email-host-user"
EMAIL_HOST_PASSWORD = "your-email-host-password"
EMAIL_RECIPIENT = "your-email-recipient"

# TELEGRAM BOT
# Telegram booking alerts (optional — leave blank to disable)
# 1. Create a bot via @BotFather and copy the token here.
# 2. Add the bot to your team group, then read the group's chat id
#    (negative number) from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-from-botfather"
TELEGRAM_CHAT_ID="your-telegram-chat-id"  # find via: python manage.py telegram_chat_id

# Google Drive Backup Configuration (info@ account)
TOKEN_PICKLE_PATH=/path/to/token.pickle
DRIVE_BACKUP_FOLDER_ID = 1abc123xyz...

# WhatsApp chat import (support@ account — the shared export folder is shared to
# support@, a DIFFERENT account from the info@ backup above, so it needs its OWN
# OAuth2 token pickle. Generate it by running the auth script signed in as support@.)
WHATSAPP_TOKEN_PICKLE_PATH=/path/to/whatsapp_support_token.pickle
WHATSAPP_DRIVE_FOLDER_ID=1shared_folder_id_here
WHATSAPP_EXPORT_TIMEZONE=Africa/Johannesburg

# Jobs-sheet export: the deployed Apps Script web-app URL (…/exec) of the APS
# Open Jobs sheet, and a shared secret that MUST match the INBOUND.TOKEN constant
# in that Apps Script's doPost function.
WHATSAPP_JOBS_SHEET_URL=https://script.google.com/macros/s/XXXX/exec
WHATSAPP_JOBS_SHEET_TOKEN=a-long-random-secret-matching-the-apps-script

# Subscriptions-sheet sync: the "APS Subscriptions" tab lives in the SAME
# spreadsheet/web-app as the jobs export (routed by a `type` field), so these
# default to the WHATSAPP_JOBS_SHEET_* values above. Only set them if you deploy
# a SEPARATE Apps Script for subscriptions.
# APS_SUBSCRIPTION_SHEET_URL=
# APS_SUBSCRIPTION_SHEET_TOKEN=

# AI Chatbot configurations (Grok)
CHATBOT_API_KEY = "your-chatbot-api-key"
CHATBOT_API_URL = "your-chatbot-api-url"

# Home Assistant fault detection (SOC imbalance monitoring)
HA_BASE_URL = "https://urbangrowth.invertermon.com"
HA_TOKEN = "your-home-assistant-long-lived-access-token"
HA_REQUEST_TIMEOUT = "15"  # seconds per request
# Comma-separated entity IDs of the 6 IES SOC sensors (replace with the real IDs)
HA_SOC_ENTITY_IDS = "sensor.ies_1_soc,sensor.ies_2_soc,sensor.ies_3_soc,sensor.ies_4_soc,sensor.ies_5_soc,sensor.ies_6_soc"
HA_SOC_IMBALANCE_THRESHOLD = "10"  # percentage points (max - min) that triggers a fault

# Charge/discharge behaviour check (battery should charge in Valley, discharge in Peak)
# APS-defined schedule is the SOURCE OF TRUTH (not the live ems_mode sensor) so that
# a client manually forcing the wrong mode on Home Assistant triggers an alert.
# Comma-separated "HH:MM-HH:MM" windows in HA_SCHEDULE_TIMEZONE; may wrap midnight.
HA_SCHEDULE_TIMEZONE = "Africa/Johannesburg"    # Cape Town / SAST (GMT+2)
HA_VALLEY_WINDOWS = "00:00-05:45,11:01-16:45"   # battery should CHARGE
HA_PEAK_WINDOWS = "05:46-11:00,16:46-23:59"     # battery should DISCHARGE
HA_BATTERY_POWER_ENTITY = "sensor.battery_power"
HA_BATTERY_SOC_ENTITY = "sensor.battery_soc"
HA_BATTERY_POWER_DEADBAND_KW = "5"   # |power| below this = idle, not charge/discharge
HA_CHARGE_FULL_SOC = "99"            # valley: can't charge past ~full, not a fault
HA_DISCHARGE_FLOOR_SOC = "20"        # peak: discharge stop SoC, can't discharge below
HA_BEHAVIOUR_PERSIST_COUNT = "2"     # wrong behaviour must persist N checks before alert

# Fault alert channels
ALERT_EMAIL_ENABLED = "False"      # "True" to email EMAIL_RECIPIENT on fault/recovery
ALERT_TELEGRAM_ENABLED = "False"   # "True" to send Telegram alerts

# PayFast Configuration
PAYFAST_SANDBOX = 'True'  # Set to "True" in Development/Testing, "False" in Production
PAYFAST_MERCHANT_ID = 'your_production_merchant_id'
PAYFAST_MERCHANT_KEY = 'your_production_merchant_key'
PAYFAST_PASSPHRASE = 'your_production_passphrase'  # Optional but recommended

# PayFast URLs - Update these based on your domain
PAYFAST_RETURN_URL = 'http://localhost:3000/payment-succeed'
PAYFAST_CANCEL_URL = 'http://localhost:3000/payment-cancelled'
PAYFAST_NOTIFY_URL = 'https://yourdomain.com/api/subscription/payfast-notify/'  # Must be publicly accessible. PayFast needs to be able to reach this URL to send payment notifications.
PAYFAST_SOLAR_CLEANING_NOTIFY_URL = 'https://yourdomain.com/api/request-solar-cleaning/payfast-notify/'  # Must be publicly accessible. PayFast needs to be able to reach this URL to send payment notifications.