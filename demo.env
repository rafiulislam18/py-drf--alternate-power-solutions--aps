# Django SECRET_KEY (use a secure key)
DJANGO_SECRET_KEY = "your-django-secret-key"

# Database configuration
DB_NAME = 'aps_db'
DB_USER = 'aps_db_user'
DB_PASSWORD = ''
DB_HOST = 'localhost'
DB_PORT = '5432'

# Email Configuration
EMAIL_HOST_USER = "your-email-host-user"
EMAIL_HOST_PASSWORD = "your-email-host-password"

# Google Drive Backup Configuration
TOKEN_PICKLE_PATH=/path/to/token.pickle
DRIVE_BACKUP_FOLDER_ID = 1abc123xyz...

# AI Chatbot configurations (Grok)
CHATBOT_API_KEY = "your-chatbot-api-key"
CHATBOT_API_URL = "your-chatbot-api-url"

# PayFast Configuration
PAYFAST_SANDBOX = 'True'  # Set to "True" in Development/Testing, "False" in Production
PAYFAST_MERCHANT_ID = 'your_production_merchant_id'
PAYFAST_MERCHANT_KEY = 'your_production_merchant_key'
PAYFAST_PASSPHRASE = 'your_production_passphrase'  # Optional but recommended

# PayFast URLs - Update these based on your domain
PAYFAST_RETURN_URL = 'http://localhost:3000/payment-succeed'
PAYFAST_CANCEL_URL = 'http://localhost:3000/payment-cancelled'
PAYFAST_NOTIFY_URL = 'https://yourdomain.com/api/subscription/payfast-notify/'  # Must be publicly accessible. PayFast needs to be able to reach this URL to send payment notifications.
PAYFAST_SOLAR_CLEANING_NOTIFY_URL = 'https://yourdomain.com/api/request-solar-cleaning/payfast-notify/'  # Must be publicly accessible. PayFast needs to be able to reach this URL to send payment notifications.